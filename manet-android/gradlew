#!/bin/sh
#
# Gradle wrapper script. Run from project root: ./gradlew assembleDebug
#
set -e
APP_HOME="$(cd "$(dirname "$0")" && pwd)"
JAR="$APP_HOME/gradle/wrapper/gradle-wrapper.jar"
if [ ! -f "$JAR" ]; then
  echo "Missing $JAR. Run: gradle wrapper" 1>&2
  exit 1
fi
exec java -cp "$JAR" org.gradle.wrapper.GradleWrapperMain "$@"
